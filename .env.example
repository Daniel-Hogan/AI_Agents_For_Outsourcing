# Copy to .env and adjust as needed.

# Local postgres from docker-compose.yml
DATABASE_URL=postgresql+psycopg2://appuser:apppassword@localhost:5433/appdb

# Change this in real deployments
JWT_SECRET=dev-change-me

# React dev server origin
FRONTEND_ORIGIN=http://localhost:5173

# Cookie settings (refresh token cookie)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# openrouteservice / OpenStreetMap travel-time integration
OPENROUTESERVICE_API_KEY=eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjVlYmUxMTIyY2M4MjQ3MGM5ZDg4ZGJkZjNiMjAxM2FiIiwiaCI6Im11cm11cjY0In0=
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
OPENROUTESERVICE_TIMEOUT_SECONDS=10
OPENROUTESERVICE_PROFILE=driving-car

# Travel warning behavior
TRAVEL_WARNING_BUFFER_MINUTES=10
TRAVEL_WARNING_TIGHT_WINDOW_MINUTES=15

# Optional fallback origin if a user has no earlier meeting/default location
ORGANIZATION_DEFAULT_LOCATION=
ORGANIZATION_DEFAULT_LOCATION_LATITUDE=
ORGANIZATION_DEFAULT_LOCATION_LONGITUDE=
