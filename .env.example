# Copy to .env and adjust as needed.

# Local postgres from docker-compose.yml
DATABASE_URL=postgresql+psycopg2://appuser:apppassword@localhost:5433/appdb

# Optional explicit pytest database. If unset, tests derive appdb_test from DATABASE_URL.
TEST_DATABASE_URL=postgresql+psycopg2://appuser:apppassword@localhost:5433/appdb_test

# Use production for public deploys. Production mode rejects unsafe defaults.
# Use staging locally for production-like UI without production security enforcement.
APP_ENV=development

# Change this in real deployments
JWT_SECRET=dev-change-me

# Optional extra CORS origin for a separate frontend. Leave empty for same-origin FastAPI/Jinja UI.
FRONTEND_ORIGIN=

# Cookie and CSRF settings
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CSRF_PROTECTION_ENABLED=false

# Optional development-only Google OAuth UI
# Production currently hides the Google login button until Google Cloud Console setup is complete.
# Local redirect URI: http://127.0.0.1:8000/web/auth/google/callback
# Production redirect URI: https://schedulerai.tech/web/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Resend email notifications
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@schedulerai.tech
EMAIL_FROM_NAME=AI Scheduler
APP_BASE_URL=http://127.0.0.1:8000

# Application logging
LOG_LEVEL=INFO

# openrouteservice / OpenStreetMap travel-time integration
OPENROUTESERVICE_API_KEY=
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
OPENROUTESERVICE_TIMEOUT_SECONDS=10
OPENROUTESERVICE_PROFILE=driving-car

# Travel warning behavior
TRAVEL_WARNING_BUFFER_MINUTES=10
TRAVEL_WARNING_TIGHT_WINDOW_MINUTES=15

# Optional fallback origin if a user has no earlier meeting/default location
ORGANIZATION_DEFAULT_LOCATION=
ORGANIZATION_DEFAULT_LOCATION_LATITUDE=
ORGANIZATION_DEFAULT_LOCATION_LONGITUDE=
